# TasteExplorer Production Environment Variables
# Copy this file to .env in production and fill in actual values

# =============================================================================
# BACKEND (API) - Set these in Render/Railway
# =============================================================================

# Database (provided by Supabase/Railway)
DATABASE_URL=postgresql://user:password@host:5432/database

# Redis (optional, for caching - provided by Railway/Upstash)
REDIS_URL=redis://default:password@host:6379

# Spotify API Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://your-api-domain.com/auth/spotify/callback

# CORS - Set to your deployed frontend URL
# For Vercel: https://your-app.vercel.app
# Multiple origins: https://app1.com,https://app2.com
CORS_ORIGINS=https://your-app.vercel.app

# Frontend URL (for redirects after auth)
FRONTEND_URL=https://your-app.vercel.app

# Environment
ENVIRONMENT=production

# Optional: SQL query logging (set to 'true' for debugging)
SQL_ECHO=false

# =============================================================================
# FRONTEND (Next.js) - Set these in Vercel
# =============================================================================

# API URL - Set to your deployed backend URL
# For Render: https://your-api.onrender.com
# For Railway: https://your-api.up.railway.app
NEXT_PUBLIC_API_URL=https://your-api.onrender.com
